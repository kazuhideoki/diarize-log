OPENAI_API_KEY=your-openai-api-key
DIARIZE_LOG_RECORDING_DURATION_SECONDS=360
DIARIZE_LOG_CAPTURE_DURATION_SECONDS=180
DIARIZE_LOG_CAPTURE_OVERLAP_SECONDS=15
DIARIZE_LOG_SPEAKER_SAMPLE_DURATION_SECONDS=6
DIARIZE_LOG_MERGE_MIN_OVERLAP_CHARS=10
DIARIZE_LOG_MERGE_ALIGNMENT_RATIO=0.80
DIARIZE_LOG_MERGE_TRIGRAM_SIMILARITY=0.55
DIARIZE_LOG_DEBUG=false
DIARIZE_LOG_STORAGE_ROOT=/absolute/path/to/storage
